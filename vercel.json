{
  "rewrites": [
    {
      "source": "/hf/:path*",
      "destination": "https://huggingface.co/:path*"
    },
    {
      "source": "/api/resolve-cache/:path*",
      "destination": "https://huggingface.co/api/resolve-cache/:path*"
    },
    {
      "source": "/anthropic/:path*",
      "destination": "https://api.anthropic.com/:path*"
    }
  ]
}
